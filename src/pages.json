{
  "easycom": {
    "autoscan": true,
    "custom": {
      "^uni-(.*)": "@dcloudio/uni-ui/lib/uni-$1/uni-$1.vue"
    }
  },
  "pages": [
    {
      "path": "pages/index/index",
      "style": {
        "navigationStyle": "custom",
        "navigationBarTitleText": "百淘云"
      }
    },
    {
      "path": "pages/monthly/index",
      "style": {
        "navigationStyle": "custom",
        "navigationBarTitleText": "本月详情"
      }
    },
    {
      "path": "pages/add/index",
      "style": {
        "navigationStyle": "custom",
        "navigationBarTitleText": "添加记录"
      }
    },
    {
      "path": "pages/profile/index",
      "style": {
        "navigationStyle": "custom",
        "navigationBarTitleText": "个人中心"
      }
    },
    {
      "path": "pages/detail/index",
      "style": {
        "navigationStyle": "custom",
        "navigationBarTitleText": "饮品详情"
      }
    },
    {
      "path": "pages/analyze/index",
      "style": {
        "navigationStyle": "custom",
        "navigationBarTitleText": "图片分析"
      }
    },
    {
      "path": "pages/store/index",
      "style": {
        "navigationStyle": "custom",
        "navigationBarTitleText": "店铺详情"
      }
    },
    {
      "path": "pages/medals/index",
      "style": {
        "navigationStyle": "custom",
        "navigationBarTitleText": "勋章馆"
      }
    }
  ],
  "globalStyle": {
    "navigationStyle": "custom",
    "navigationBarBackgroundColor": "#f9f9f9",
    "navigationBarTextStyle": "black",
    "backgroundColor": "#f9f9f9",
    "backgroundTextStyle": "light"
  },
  "tabBar": {
    "custom": true,
    "color": "#3d4947",
    "selectedColor": "#006860",
    "backgroundColor": "#f9f9f9",
    "list": [
      {
        "pagePath": "pages/index/index",
        "text": "首页"
      },
      {
        "pagePath": "pages/monthly/index",
        "text": "统计"
      },
      {
        "pagePath": "pages/profile/index",
        "text": "我的"
      }
    ]
  }
}
